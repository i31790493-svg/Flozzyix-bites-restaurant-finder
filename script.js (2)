const locationBtn = document.getElementById("locationBtn");
const restaurants = document.getElementById("restaurants");
const map = document.querySelector(".map-placeholder");

locationBtn.addEventListener("click", () => {
    navigator.geolocation.getCurrentPosition(success, error);
});

function success(position) {
    const lat = position.coords.latitude;
    const lon = position.coords.longitude;

    // Show map
    map.innerHTML = `
        <iframe
            width="100%"
            height="100%"
            style="border:0;border-radius:15px;"
            src="https://www.openstreetmap.org/export/embed.html?bbox=${lon-0.01},${lat-0.01},${lon+0.01},${lat+0.01}&layer=mapnik&marker=${lat},${lon}">
        </iframe>
    `;

    loadRestaurants(lat, lon);
}

function error() {
    alert("Please allow location access.");
}

async function loadRestaurants(lat, lon) {

    restaurants.innerHTML = "<h2>Nearby Restaurants</h2><p>Loading...</p>";

    const query = `
[out:json];
(
 node["amenity"="restaurant"](around:3000,${lat},${lon});
);
out;
`;

    const response = await fetch(
        "https://overpass-api.de/api/interpreter",
        {
            method: "POST",
            body: query
        }
    );

    const data = await response.json();

    restaurants.innerHTML = "<h2>Nearby Restaurants</h2>";

    data.elements.forEach(place => {

        restaurants.innerHTML += `
        <div class="card">
            <h3>${place.tags.name || "Unnamed Restaurant"}</h3>
            <p>📍 ${place.tags["addr:street"] || "Address unavailable"}</p>
            <button onclick="window.open('https://www.openstreetmap.org/?mlat=${place.lat}&mlon=${place.lon}','_blank')">
                View on Map
            </button>
        </div>
        `;
    });
}